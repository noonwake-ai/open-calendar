{
    "name": "pi_hexagram_report",
    "description": "根据用户的卦象、问题与生辰信息，由当前值班十神给出简短灵纹解读。输出必须为严格 JSON，适合 TTS 朗读。",
    "strict": true,
    "schema": {
        "type": "object",
        "properties": {
            "reading": {
                "type": "string",
                "maxLength": 50,
                "description": "简短的灵纹解读，50字以内，口语化，TTS会朗读。要体现当前十神的独特视角，紧扣用户问题给出明确判断，用生活化比喻，不说空话套话。"
            },
            "inscription": {
                "type": "array",
                "items": { "type": "string" },
                "minItems": 2,
                "maxItems": 2,
                "description": "签文，恰好2个字符串，每个固定4个字。凝练灵纹精髓，与用户问题和灵纹解读呼应。例如 [\"顺势而为\", \"天地通达\"]。"
            },
            "meaning": {
                "type": "string",
                "maxLength": 20,
                "description": "辞意，一句话不超过20字，概括灵纹对用户问题的核心启示。"
            },
            "blessings": {
                "type": "array",
                "maxItems": 3,
                "description": "需要祈福的事项列表，可为空数组。当用户问题涉及具体行动、决策、时机时给出。事项必须直接围绕用户这次摇卦提问的单一事件，不要泛化成日常建议。",
                "items": {
                    "type": "object",
                    "properties": {
                        "item": {
                            "type": "string",
                            "maxLength": 8,
                            "description": "祈福事项，必须直接推进用户这次提问的那件事，像待办一样简洁明确，不超过8个字。"
                        },
                        "reason": {
                            "type": "string",
                            "maxLength": 35,
                            "description": "原因解读，不超过35个字，要直接说明为什么这一步能推进用户这次提问的那件事，并与卦象、问题、阶段卡点呼应。"
                        },
                        "tag": {
                            "type": "string",
                            "enum": ["love", "wealth", "study", "career"],
                            "description": "四大运势分类标签。love 对应桃花/家人/感情/约会等；wealth 对应财/理财/投资/收支等；study 对应学习/阅读/复习/课程等；其余默认 career。"
                        },
                        "date": {
                            "type": "string",
                            "description": "具体日期，格式 YYYY-MM-DD，根据当前时间推算出合适的日期。"
                        }
                    },
                    "required": ["item", "reason", "tag", "date"],
                    "additionalProperties": false
                }
            }
        },
        "required": ["reading", "inscription", "meaning", "blessings"],
        "additionalProperties": false
    }
}
