{
    "compilerOptions": {
        "target": "ES2022",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "allowSyntheticDefaultImports": true,
        "types": ["node"],
        "strict": true,
        "skipLibCheck": true,
        "noEmit": true,
        "composite": true,
        "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.node.tsBuildInfo"
    },
    "include": ["vite.config.ts"]
}
